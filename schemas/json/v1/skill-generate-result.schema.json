{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kernel.local/schemas/json/v1/skill-generate-result.schema.json",
  "title": "Kernel Skill Generate Result v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "generationSet", "dryRun", "skills", "files", "skipped"],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "generationSet": {
      "enum": ["mvp", "lint-ready"]
    },
    "dryRun": {
      "type": "boolean"
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "files": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/fileResult"
      }
    },
    "skipped": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["skillName", "relativePath", "reasons"],
        "properties": {
          "skillName": {
            "type": "string",
            "minLength": 1
          },
          "relativePath": {
            "type": "string",
            "minLength": 1
          },
          "reasons": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["code", "message"],
              "properties": {
                "code": {
                  "type": "string",
                  "minLength": 1
                },
                "message": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        }
      }
    }
  },
  "definitions": {
    "fileResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["relativePath", "path", "action"],
      "properties": {
        "relativePath": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "action": {
          "enum": ["created", "updated", "would-create", "would-update"]
        }
      }
    }
  }
}
