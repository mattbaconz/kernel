{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kernel.local/schemas/json/v1/error-envelope.schema.json",
  "title": "Kernel JSON Error Envelope v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "status", "error"],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "status": {
      "const": "error"
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "command", "message"],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1
        },
        "command": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "runnerId": {
          "type": "string",
          "minLength": 1
        },
        "schemaName": {
          "type": "string",
          "minLength": 1
        },
        "schemaVersionId": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
